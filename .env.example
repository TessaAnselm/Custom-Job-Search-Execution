# AI
OPENAI_API_KEY=sk-...

# Google Sheets
GOOGLE_SHEETS_ID=your-spreadsheet-id-here
# Path to a service account JSON file, OR paste the JSON inline below
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_INLINE={"type":"service_account",...}

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# Alerts — at least one required
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_NOTIFY_TO=you@gmail.com   # defaults to GMAIL_USER

# Optional: LinkedIn session cookie for scraping
# Log in to linkedin.com in your browser, open DevTools → Application → Cookies → li_at
LINKEDIN_LI_AT=
