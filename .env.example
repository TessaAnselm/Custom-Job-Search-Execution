# ── AI Provider ──────────────────────────────────────────────────────────────
# Pick one provider and fill in only that section.
# Options: gemini | anthropic | groq | openai | ollama
AI_PROVIDER=gemini

# --- Google Gemini (FREE tier — recommended) ---
# Get your free key at https://aistudio.google.com → Get API Key
# Free tier: 1,500 requests/day, 1M tokens/day on Gemini 1.5 Flash
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash     # or gemini-1.5-pro for higher quality

# --- Anthropic Claude ---
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # fast + cheap; or claude-sonnet-4-6

# --- Groq (FREE tier — fast open-source models) ---
# Get free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI ---
# No free tier. Pay-as-you-go at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (100% free — runs locally, no key needed) ---
# Install from https://ollama.com, then: ollama pull llama3
OLLAMA_MODEL=llama3

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=your-spreadsheet-id-here
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ── Alerts (at least one recommended) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_NOTIFY_TO=you@gmail.com

# ── Scrapers ──────────────────────────────────────────────────────────────────
# LinkedIn only — session cookie from your browser
LINKEDIN_LI_AT=
