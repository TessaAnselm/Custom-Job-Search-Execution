name: "Your Name"

target_titles:
  - "Senior Software Engineer"
  - "Staff Engineer"
  - "Security Engineer"
  - "DevOps Engineer"

skills:
  - Python
  - JavaScript
  - Docker
  - Kubernetes
  - Linux
  - SQL

location:
  preferred:
    - "Remote"
    - "San Francisco"
    - "New York"
  hard_no:
    - "Requires Relocation"

salary:
  minimum: 120000
  target: 160000

role_type: IC   # IC | Manager | Either

experience_years: 3

industries:
  preferred:
    - "Dev Tools"
    - "Fintech"
    - "Cloud Infrastructure"
  avoid:
    - "Gambling"
    - "AdTech"

scoring_weights:
  title_match: 0.30
  skills_match: 0.25
  salary_match: 0.20
  location_match: 0.15
  industry_match: 0.10

minimum_score: 65

# Paste the text of your base resume here.
# This is used by the AI to tailor a version for each job and to draft cover notes.
base_resume: |
  Your Name
  email@example.com | linkedin.com/in/yourhandle | github.com/yourhandle

  SUMMARY
  [2-3 sentence summary of your background and what you're looking for]

  SKILLS
  [List your key technical skills]

  EXPERIENCE
  [Your most recent role — company, title, dates, 2-3 bullet points]

  PROJECTS
  [Any notable projects with a short description]

  EDUCATION
  [School, degree or program, graduation year]
